generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Starter models — replace with your own
// ─────────────────────────────────────────
// ADMIN USER
// ─────────────────────────────────────────
enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String     // bcrypt hashed
  role      UserRole   @default(STAFF)
  isActive  Boolean    @default(true)
  avatarUrl String?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt

  proposals        Proposal[]
  proposalTemplates ProposalTemplate[]
}

// ─────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────
model Booking {
  id            String          @id @default(cuid())

  // Client info
  clientName    String
  clientEmail   String
  clientPhone   String

  // Event info
  eventType     EventType
  eventDate     DateTime
  location      String
  guestCount    Int?
  budgetRange   BudgetRange
  notes         String?         @db.Text

  // Status
  status        BookingStatus   @default(NEW_REQUEST)

  // Internal
  internalNotes String?         @db.Text
  assignedTo    String?         // name of coordinator

  // Payment tracking
  agreedAmount  Float?
  depositAmount Float?
  depositPaid   Boolean         @default(false)
  depositDate   DateTime?
  balancePaid   Boolean         @default(false)
  balanceDate   DateTime?

  // Relations
  messages      Message[]
  invitations   WeddingInvitation[]

  // Timestamps
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Proposals
  proposals     Proposal[]
}

enum EventType {
  WEDDING
  BIRTHDAY
  CORPORATE
  GRADUATION
  ENGAGEMENT
  ANNIVERSARY
  CULTURAL
  OTHER
}

enum BudgetRange {
  UNDER_50K       // Under ETB 50,000
  RANGE_50K_100K  // ETB 50,000 – 100,000
  RANGE_100K_200K // ETB 100,000 – 200,000
  RANGE_200K_500K // ETB 200,000 – 500,000
  ABOVE_500K      // Above ETB 500,000
}

enum BookingStatus {
  NEW_REQUEST
  CONTACTED
  CONFIRMED
  PLANNED
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────
// MESSAGES (Client Communication Log)
// ─────────────────────────────────────────
model Message {
  id        String         @id @default(cuid())
  bookingId String
  booking   Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender    MessageSender
  content   String         @db.Text
  createdAt DateTime       @default(now())
}

enum MessageSender {
  ADMIN
  SYSTEM  // auto-generated status change messages
}

// ─────────────────────────────────────────
// GALLERY
// ─────────────────────────────────────────
model GalleryImage {
  id              String           @id @default(cuid())
  title           String
  description     String?
  imageUrl        String           // Supabase Storage URL
  category        GalleryCategory
  isFeatured      Boolean          @default(false)
  isBeforeAfter   Boolean          @default(false)
  beforeImageUrl  String?          // only if isBeforeAfter = true
  afterImageUrl   String?          // only if isBeforeAfter = true
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
}

enum GalleryCategory {
  WEDDINGS
  BIRTHDAYS
  CORPORATE
  DECORATIONS
  BEHIND_THE_SCENES
}

// ─────────────────────────────────────────
// SERVICE PACKAGES
// ─────────────────────────────────────────
model PackageCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  coverImage  String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  packages    Package[]
}

model Package {
  id            String          @id @default(cuid())

  categoryId    String
  category      PackageCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  name          String
  shortDesc     String          @default("")
  description   String          @db.Text

  price         Float?
  priceLabel    String

  features      String[]
  exclusions    String[]        @default([])

  imageUrl      String?
  galleryImages String[]        @default([])

  isPopular     Boolean         @default(false)
  isFeatured    Boolean         @default(false)
  isActive      Boolean         @default(true)
  sortOrder     Int             @default(0)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// WEDDING DIGITAL EXPERIENCE
model WeddingInvitation {
  id             String          @id @default(cuid())

  bookingId      String          @unique
  booking        Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  brideName      String
  groomName      String
  slug           String          @unique

  weddingDate    DateTime
  weddingTime    String

  venueName      String
  venueAddress   String
  dressCode      String?
  mapUrl         String?

  welcomeMessage String?         @db.Text
  story          String?         @db.Text
  heroImageUrl   String?
  coverImage     String?
  galleryImages  String[]        @default([])

  templateKey    String          @default("FLORAL_LUXURY")
  theme          InvitationTheme @default(FLORAL_LUXURY)
  themeColor     String?
  primaryColor   String?
  secondaryColor String?
  customMessage  String?         @db.Text

  floralTopLeft     String?
  floralTopRight    String?
  floralBottomLeft  String?
  floralBottomRight String?

  status         InvitationStatus @default(DRAFT)
  allowRSVP      Boolean          @default(true)
  allowGiftRegistry Boolean       @default(true)
  publishedAt    DateTime?
  isPublished    Boolean         @default(false)
  pdfUrl         String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  gifts          GiftRegistry[]
  reservations   GiftReservation[]
  rsvps          RSVP[]
}

model RSVP {
  id             String            @id @default(cuid())

  invitationId   String
  invitation     WeddingInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  guestName      String
  guestPhone     String?
  attendance     RSVPStatus
  message        String?           @db.Text

  createdAt      DateTime          @default(now())
}

model GiftRegistry {
  id             String            @id @default(cuid())

  invitationId   String
  invitation     WeddingInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  giftName       String
  title          String?
  description    String?
  imageUrl       String?
  priority       Int               @default(1)
  priorityLabel  GiftPriority      @default(MEDIUM)
  allowDuplicates Boolean          @default(false)

  isReserved     Boolean           @default(false)
  reservedBy     String?
  reservedMessage String?

  createdAt      DateTime          @default(now())

  reservations   GiftReservation[]
}

model GiftReservation {
  id             String            @id @default(cuid())

  invitationId   String
  invitation     WeddingInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  giftId         String
  gift           GiftRegistry      @relation(fields: [giftId], references: [id], onDelete: Cascade)

  reservedBy     String
  reservedMessage String?

  createdAt      DateTime          @default(now())
}

model DesignAsset {
  id        String        @id @default(cuid())
  name      String
  imageUrl  String
  category  AssetCategory
  createdAt DateTime      @default(now())
}

enum InvitationTheme {
  FLORAL_LUXURY
  MODERN_MINIMAL
  ROYAL_GOLD
  TRADITIONAL_ETHIOPIAN
  ELEGANT_BLACK
  GARDEN_WEDDING
  LUXURY_WHITE
  CLASSIC_SERIF
}

enum RSVPStatus {
  ATTENDING
  NOT_ATTENDING
  MAYBE
  ACCEPTED
  DECLINED
}

enum InvitationStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum GiftPriority {
  LOW
  MEDIUM
  HIGH
}

enum AssetCategory {
  FLORAL
  FRAME
  ORNAMENT
  TEXTURE
}

// ─────────────────────────────────────────
// PROPOSAL & QUOTATION SYSTEM
// ─────────────────────────────────────────

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
}

enum ProposalItemCategory {
  DECORATION
  CATERING
  PHOTOGRAPHY
  VENUE
  ENTERTAINMENT
  FLORAL
  LIGHTING
  TRANSPORT
  COORDINATION
  CUSTOM
}

model Proposal {
  id              String          @id @default(cuid())

  bookingId       String
  booking         Booking         @relation(fields: [bookingId], references: [id])

  title           String
  proposalNumber  String          @unique
  introduction    String?         @db.Text
  eventVision     String?         @db.Text
  themeConcept    String?         @db.Text

  totalAmount     Float
  currency        String          @default("ETB")
  status          ProposalStatus  @default(DRAFT)
  validUntil      DateTime?

  pdfUrl          String?
  publicToken     String          @unique
  clientApproved  Boolean         @default(false)
  clientApprovedAt DateTime?
  clientRejected  Boolean         @default(false)
  rejectionReason String?

  notes           String?         @db.Text

  createdById     String
  createdBy       User            @relation(fields: [createdById], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           ProposalItem[]
  sections        ProposalSection[]
  contracts       ProposalContract[]
  comments        ProposalComment[]
}

model ProposalItem {
  id          String              @id @default(cuid())

  proposalId  String
  proposal    Proposal            @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  title       String
  description String?
  quantity    Int                 @default(1)
  unitPrice   Float
  totalPrice  Float
  category    ProposalItemCategory
  sortOrder   Int                 @default(0)

  createdAt   DateTime            @default(now())
}

model ProposalSection {
  id          String              @id @default(cuid())

  proposalId  String
  proposal    Proposal            @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  title       String
  content     String              @db.Text
  sortOrder   Int                 @default(0)

  createdAt   DateTime            @default(now())
}

model ProposalContract {
  id          String              @id @default(cuid())

  proposalId  String
  proposal    Proposal            @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  title       String
  content     String              @db.Text

  createdAt   DateTime            @default(now())
}

model ProposalComment {
  id          String              @id @default(cuid())

  proposalId  String
  proposal    Proposal            @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  authorName  String
  content     String              @db.Text

  createdAt   DateTime            @default(now())
}

model ProposalTemplate {
  id            String            @id @default(cuid())

  name          String
  description   String?
  eventType     EventType?
  coverImage    String?

  sections      String            @db.Text    // JSON array of template sections
  contractTerms String?           @db.Text

  isActive      Boolean           @default(true)
  createdById   String
  createdBy     User              @relation(fields: [createdById], references: [id])

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}
